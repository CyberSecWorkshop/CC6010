<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CC6010 – Incident Response Quiz</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@400;600;800&display=swap');

  :root {
    --bg: #0a0e1a;
    --surface: #111827;
    --card: #161f30;
    --border: #1e2d45;
    --accent: #00e5ff;
    --accent2: #ff4d6d;
    --correct: #00ff87;
    --wrong: #ff4d6d;
    --text: #e2eaf4;
    --muted: #6b7fa3;
    --mono: 'JetBrains Mono', monospace;
    --sans: 'Syne', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    min-height: 100vh;
    padding: 2rem 1rem 4rem;
    background-image:
      radial-gradient(ellipse 80% 40% at 50% -10%, rgba(0,229,255,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 50% 30% at 90% 80%, rgba(255,77,109,0.05) 0%, transparent 60%);
  }

  header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 3rem;
  }

  .tag {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--accent);
    border: 1px solid rgba(0,229,255,0.3);
    padding: 4px 12px;
    border-radius: 2px;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  h1 span { color: var(--accent); }

  .subtitle {
    color: var(--muted);
    font-size: 0.95rem;
    font-family: var(--mono);
  }

  .quiz-container {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .question-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.3s;
    position: relative;
    overflow: hidden;
  }

  .question-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 100%;
    background: var(--accent);
    opacity: 0.4;
  }

  .question-card.answered::before { opacity: 1; }
  .question-card.correct-card::before { background: var(--correct); }
  .question-card.wrong-card::before { background: var(--wrong); }

  .q-number {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 0.6rem;
    text-transform: uppercase;
  }

  .q-text {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.5;
    margin-bottom: 1.2rem;
    color: #cdd9ee;
  }

  .options {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .option {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
    background: transparent;
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--text);
    text-align: left;
    line-height: 1.4;
  }

  .option:hover:not(:disabled) {
    border-color: var(--accent);
    background: rgba(0,229,255,0.04);
  }

  .option-letter {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
    min-width: 1.2rem;
    padding-top: 1px;
    flex-shrink: 0;
  }

  .option.correct {
    border-color: var(--correct);
    background: rgba(0,255,135,0.06);
    color: var(--correct);
  }

  .option.correct .option-letter { color: var(--correct); }

  .option.wrong {
    border-color: var(--wrong);
    background: rgba(255,77,109,0.06);
    color: var(--wrong);
  }

  .option.wrong .option-letter { color: var(--wrong); }

  .option.reveal-correct {
    border-color: rgba(0,255,135,0.4);
    background: rgba(0,255,135,0.03);
    color: var(--correct);
  }

  .option:disabled { cursor: default; }

  .feedback {
    margin-top: 1rem;
    padding: 0.8rem 1rem;
    border-radius: 5px;
    font-family: var(--mono);
    font-size: 0.8rem;
    line-height: 1.6;
    display: none;
    border-left: 3px solid;
  }

  .feedback.show { display: block; }
  .feedback.correct-fb { border-color: var(--correct); background: rgba(0,255,135,0.05); color: #a0ffd4; }
  .feedback.wrong-fb { border-color: var(--wrong); background: rgba(255,77,109,0.05); color: #ffa0b2; }

  .score-panel {
    max-width: 760px;
    margin: 2rem auto 0;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem;
    text-align: center;
    display: none;
  }

  .score-panel.show { display: block; }

  .score-big {
    font-size: 4rem;
    font-weight: 800;
    font-family: var(--mono);
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .score-label {
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .grade-badge {
    display: inline-block;
    padding: 6px 20px;
    border-radius: 4px;
    font-family: var(--mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .reset-btn {
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-family: var(--mono);
    font-size: 0.85rem;
    padding: 10px 28px;
    border-radius: 4px;
    cursor: pointer;
    letter-spacing: 0.1em;
    transition: all 0.2s;
    text-transform: uppercase;
  }

  .reset-btn:hover { background: rgba(0,229,255,0.1); }

  .progress-bar {
    max-width: 760px;
    margin: 0 auto 2rem;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), #00b4d8);
    transition: width 0.4s ease;
    width: 0%;
  }

  .progress-text {
    max-width: 760px;
    margin: 0 auto 0.5rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--muted);
    display: flex;
    justify-content: space-between;
  }
</style>
</head>
<body>

<header>
  <div class="tag">CC6010 · Digital Investigation &amp; E-Discovery</div>
  <h1>Introduction to<br><span>Incident Response</span></h1>
  <p class="subtitle">Lecture 17 — 20-question multiple choice quiz</p>
</header>

<div class="progress-text">
  <span id="prog-label">0 / 20 answered</span>
  <span id="score-label">Score: 0</span>
</div>
<div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>

<div class="quiz-container" id="quiz"></div>

<div class="score-panel" id="score-panel">
  <div class="score-big" id="final-score">0/20</div>
  <div class="score-label">Final Score</div>
  <div class="grade-badge" id="grade-badge"></div>
  <br>
  <button class="reset-btn" onclick="resetQuiz()">↺ Retake Quiz</button>
</div>

<script>
const questions = [
  {
    q: "Which of the following best defines 'Incident Response'?",
    options: [
      "A tool used to scan for network vulnerabilities",
      "An organized approach to addressing and managing the aftermath of a security breach or cyberattack",
      "A policy for encrypting sensitive data at rest",
      "A legal framework for prosecuting cybercriminals"
    ],
    answer: 1,
    explanation: "Incident Response is an organized approach to addressing and managing the aftermath of a security breach or cyberattack. The goal is to handle the situation in a way that limits damage and reduces recovery time and costs."
  },
  {
    q: "What is a 'Security Incident' according to the lecture?",
    options: [
      "Any planned maintenance activity on an information system",
      "A scheduled penetration test authorized by management",
      "An attempted or successful unauthorized access, use, disclosure, modification, or destruction of information or interference with system operations",
      "A natural disaster that causes system downtime"
    ],
    answer: 2,
    explanation: "A security incident is defined as an attempted or successful unauthorized access, use, disclosure, modification, or destruction of information or interference with system operations in an information system."
  },
  {
    q: "What is 'dwell time' in the context of incident response?",
    options: [
      "The time taken to restore services after an incident is resolved",
      "The number of days an IR team spends in the war room",
      "The number of days from when an adversary initially gains access to when they are detected",
      "The duration of the post-incident lessons learned meeting"
    ],
    answer: 2,
    explanation: "Dwell time is the number of days from the time the adversary initially got in to the time they were detected. Minimising dwell time is critical — examples include Home Depot (5 months) and Sony (~1 year)."
  },
  {
    q: "According to the Cyber Kill Chain, which stage comes immediately after Weaponization?",
    options: ["Exploitation", "Delivery", "Installation", "Reconnaissance"],
    answer: 1,
    explanation: "The Cyber Kill Chain stages in order are: Reconnaissance → Weaponization → Delivery → Exploitation → Installation → Command and Control (C2) → Exfiltration. Delivery follows Weaponization."
  },
  {
    q: "Which of the following is NOT listed as a goal of Incident Response?",
    options: [
      "Limit the technical damage",
      "Limit the financial damage",
      "Prosecute all attackers in a court of law",
      "Quickly restore services"
    ],
    answer: 2,
    explanation: "The goals of IR include limiting scope, technical damage, financial damage, collateral damage, quickly restoring services, and mitigating vulnerabilities. Prosecuting attackers is not listed as a primary IR goal."
  },
  {
    q: "What does the acronym PICERL stand for in the SANS IR framework?",
    options: [
      "Plan, Investigate, Contain, Eliminate, Restore, Log",
      "Preparation, Identification, Containment, Eradication, Recovery, Lessons Learned",
      "Prevent, Identify, Control, Eject, Remediate, Launch",
      "Protect, Inspect, Contain, Evaluate, Respond, Learn"
    ],
    answer: 1,
    explanation: "SANS breaks incident response into 6 phases: Preparation, Identification, Containment, Eradication, Recovery, and Lessons Learned — forming the acronym PICERL."
  },
  {
    q: "During which PICERL phase would you patch vulnerabilities and remove malicious software?",
    options: ["Preparation", "Containment", "Eradication", "Recovery"],
    answer: 2,
    explanation: "Eradication involves actually getting rid of the problem — cleanup activities such as uninstalling infected software, running AV, rebuilding the OS, and patching vulnerabilities."
  },
  {
    q: "Which of the following is an example of Internal Discovery of an incident?",
    options: [
      "Law enforcement contacts your organisation about stolen data",
      "A news report reveals your customer data is for sale online",
      "An Intrusion Detection System flags suspicious traffic on your network",
      "An external fraud monitoring service alerts you to unusual transactions"
    ],
    answer: 2,
    explanation: "Internal discovery occurs when your organisation finds the incident without external assistance — e.g., via continuous monitoring programs, Intrusion Detection Systems, or internal security processes like a SOC."
  },
  {
    q: "According to the 2018 Mandiant M-Trends data cited in the lecture, approximately how long was Sony's dwell time?",
    options: ["5 months", "11 months", "~1 year", "2 weeks"],
    answer: 2,
    explanation: "Sony's dwell time was approximately 1 year. The lecture also cites Home Depot (5 months), PF Chang's (11 months), and OPM (~1 year) as examples of extended dwell times."
  },
  {
    q: "Globally, how does internal discovery compare to external notification in terms of detection speed?",
    options: [
      "External notification is faster at 57.5 days vs 186 days for internal",
      "Internal discovery averages 57.5 days compared to 186 days for external notification",
      "Both methods take approximately 120 days on average",
      "Internal discovery takes over 300 days compared to 57.5 days externally"
    ],
    answer: 1,
    explanation: "Globally, internal discovery averages 57.5 days compared to 186 days when relying on external notification — making internal discovery significantly faster and more effective."
  },
  {
    q: "Why can organisations NOT rely solely on external notification for incident discovery?",
    options: [
      "External parties are legally prohibited from sharing threat intelligence",
      "It is not guaranteed, is probably slow, and offers limited visibility compared to internal processes",
      "External notifications are always false positives",
      "Regulatory frameworks forbid accepting external incident notifications"
    ],
    answer: 1,
    explanation: "External notification is unreliable because it is not guaranteed, it is probably slow, and external parties have limited visibility. Internal processes are more likely to detect incidents early, especially misuse of assets."
  },
  {
    q: "During the Preparation phase, what is a 'flyaway kit'?",
    options: [
      "A legal document authorising the IR team to respond to incidents",
      "A pre-prepared set of tools, equipment, and resources ready for immediate deployment during an incident",
      "A communication protocol for notifying stakeholders",
      "A backup network segment isolated from production"
    ],
    answer: 1,
    explanation: "A flyaway kit is a pre-assembled set of tools, equipment, and resources (laptops, cables, drives, etc.) that can be quickly deployed when an incident occurs, ensuring the IR team is ready to respond without delay."
  },
  {
    q: "Which of the following tools is listed in the lecture as a Network Forensics tool used in IR preparation?",
    options: ["Metasploit", "Burp Suite", "Suricata", "John the Ripper"],
    answer: 2,
    explanation: "The lecture lists Snort, Suricata, Sguil, Wireshark, Nmap, and Volatility as network forensics tools. Suricata is specifically named as an open-source intrusion detection/prevention tool."
  },
  {
    q: "In the Identification phase, which of the following would be classified as a Level 3 incident?",
    options: [
      "Unauthorized Access",
      "Denial of Service",
      "Malicious Code",
      "Improper Usage"
    ],
    answer: 2,
    explanation: "The incident classification levels are: L1 – Unauthorized Access, L2 – Denial of Service, L3 – Malicious Code, L4 – Improper Usage, L5 – Scans/Probes/Attempted Access, L6 – Investigation Incident."
  },
  {
    q: "What are Indicators of Compromise (IOCs) used for?",
    options: [
      "Encrypting forensic evidence to prevent tampering",
      "Creating legal warrants for law enforcement",
      "Running against other systems on the network to identify potentially compromised hosts",
      "Generating automated patches for vulnerable systems"
    ],
    answer: 2,
    explanation: "During Identification, IOCs (Indicators of Compromise) are created from evidence found in the investigation and then run against other systems on the network to determine if the compromise has spread."
  },
  {
    q: "During the Containment phase, which of the following is NOT one of the three options listed for containing an infection?",
    options: [
      "Disconnect affected systems from the network",
      "Shut down all systems immediately",
      "Reimage all affected systems immediately",
      "Continue to allow systems to run but closely monitor them"
    ],
    answer: 2,
    explanation: "The three containment options are: (1) disconnect affected systems, (2) shut down all systems immediately, (3) continue to allow systems to run but closely monitor them. Reimaging is part of Eradication, not Containment."
  },
  {
    q: "Why is it important to notify the business unit before shutting down systems during Containment?",
    options: [
      "Legal regulations require a 24-hour notice before any system shutdown",
      "Critical business resources may need to remain online and stakeholders must be aware of the impact",
      "Business units hold the encryption keys needed to safely power down servers",
      "The IR team needs business unit approval to access the physical hardware"
    ],
    answer: 1,
    explanation: "Before shutting down systems, you must ensure the business unit is aware, because critical resources may need to stay online and unexpected shutdowns can cause significant operational disruption."
  },
  {
    q: "During the Recovery phase, what is 'system validation'?",
    options: [
      "Verifying that legal documentation is complete before going back online",
      "Confirming that the system is operating as expected, all components are operational, and data is intact",
      "Running a penetration test to find new vulnerabilities",
      "Validating user credentials after a password reset"
    ],
    answer: 1,
    explanation: "System validation in the Recovery phase confirms that the restored system is operating as expected, all components are functional, and data is intact before returning it to normal operations."
  },
  {
    q: "Which of the following is a key concern the lecture highlights about the Recovery phase?",
    options: [
      "Making sure the attacker's IP address is published publicly",
      "Ensuring all systems are patched before going back online — never return a previously compromised vulnerable system to production",
      "Replacing all hardware that was touched by the attacker",
      "Notifying every user in the organisation via email"
    ],
    answer: 1,
    explanation: "A critical point in Recovery is to make sure systems are properly patched. Returning a vulnerable, previously compromised system back online exposes the organisation to immediate re-compromise."
  },
  {
    q: "Which of the following questions is most relevant to the Lessons Learned (Follow-Up) phase?",
    options: [
      "Which systems should be disconnected from the network first?",
      "Which team member will lead the technical response?",
      "Was there enough preparation, and how can we prevent this from happening again?",
      "What type of malware was delivered via the phishing email?"
    ],
    answer: 2,
    explanation: "The Lessons Learned / Follow-Up phase focuses on reviewing the entire IR process: Was there enough prep? Did detection occur in a timely fashion? What didn't go smoothly? How can we prevent recurrence?"
  }
];

let answered = 0;
let score = 0;
const TOTAL = questions.length;

function buildQuiz() {
  const container = document.getElementById('quiz');
  container.innerHTML = '';
  answered = 0;
  score = 0;
  updateProgress();

  questions.forEach((q, i) => {
    const card = document.createElement('div');
    card.className = 'question-card';
    card.id = `card-${i}`;

    const letters = ['A', 'B', 'C', 'D'];

    card.innerHTML = `
      <div class="q-number">Question ${String(i+1).padStart(2,'0')} / ${TOTAL}</div>
      <div class="q-text">${q.q}</div>
      <div class="options">
        ${q.options.map((opt, j) => `
          <button class="option" data-q="${i}" data-opt="${j}" onclick="selectAnswer(${i},${j})">
            <span class="option-letter">${letters[j]}</span>
            <span>${opt}</span>
          </button>
        `).join('')}
      </div>
      <div class="feedback" id="fb-${i}"></div>
    `;
    container.appendChild(card);
  });

  document.getElementById('score-panel').classList.remove('show');
}

function selectAnswer(qIndex, optIndex) {
  const q = questions[qIndex];
  const card = document.getElementById(`card-${qIndex}`);
  const buttons = card.querySelectorAll('.option');
  const fb = document.getElementById(`fb-${qIndex}`);

  buttons.forEach(b => b.disabled = true);

  const isCorrect = optIndex === q.answer;

  buttons[optIndex].classList.add(isCorrect ? 'correct' : 'wrong');
  if (!isCorrect) {
    buttons[q.answer].classList.add('reveal-correct');
  }

  card.classList.add('answered', isCorrect ? 'correct-card' : 'wrong-card');

  fb.className = `feedback show ${isCorrect ? 'correct-fb' : 'wrong-fb'}`;
  fb.innerHTML = `${isCorrect ? '✓ Correct' : '✗ Incorrect'} — ${q.explanation}`;

  if (isCorrect) score++;
  answered++;
  updateProgress();

  if (answered === TOTAL) {
    setTimeout(showScore, 600);
  }
}

function updateProgress() {
  document.getElementById('prog-label').textContent = `${answered} / ${TOTAL} answered`;
  document.getElementById('score-label').textContent = `Score: ${score}`;
  document.getElementById('progress-fill').style.width = `${(answered / TOTAL) * 100}%`;
}

function showScore() {
  const panel = document.getElementById('score-panel');
  const pct = Math.round((score / TOTAL) * 100);
  document.getElementById('final-score').textContent = `${score}/${TOTAL}`;

  const badge = document.getElementById('grade-badge');
  let grade, color;
  if (pct >= 90) { grade = 'Excellent — A'; color = '#00ff87'; }
  else if (pct >= 75) { grade = 'Good — B'; color = '#00e5ff'; }
  else if (pct >= 60) { grade = 'Pass — C'; color = '#ffd700'; }
  else { grade = 'Needs Revision — F'; color = '#ff4d6d'; }

  badge.textContent = grade;
  badge.style.background = color + '15';
  badge.style.border = `1px solid ${color}`;
  badge.style.color = color;

  panel.classList.add('show');
  panel.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

function resetQuiz() {
  buildQuiz();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

buildQuiz();
</script>
</body>
</html>
